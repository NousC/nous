# =============================================================================
# Proply CRM — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# =============================================================================
# === Supabase (required)
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# === API Server
# =============================================================================
PORT=3000
NODE_ENV=development
API_URL=http://localhost:3000

# Secret used to sign API keys issued to users
API_SECRET=your-random-secret-here

# =============================================================================
# === Frontend
# =============================================================================
VITE_API_URL=http://localhost:3000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# =============================================================================
# === AI Providers (at least one required for memory synthesis)
# =============================================================================
ANTHROPIC_API_KEY=your-anthropic-key
# OPENAI_API_KEY=your-openai-key        # optional alternative

# =============================================================================
# === Integrations (all optional — connect the ones you use)
# =============================================================================

# --- Google Calendar ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# --- LinkedIn via Unipile ---
UNIPILE_API_KEY=
UNIPILE_DSN=

# --- Email (Gmail / Outlook) ---
# Configured per-user via OAuth in the app. No global key needed.

# --- Webhook security ---
WEBHOOK_HMAC_SECRET=your-webhook-secret
