# ── Domains (used by Caddy for SSL + routing) ─────────────────────────────────
APP_DOMAIN=app.yourdomain.com
API_DOMAIN=api.yourdomain.com
# Hosted MCP server (Streamable HTTP). Point a DNS record at the server; Caddy
# auto-provisions TLS. Remote MCP clients (n8n cloud, etc.) connect to https://$MCP_DOMAIN/mcp
MCP_DOMAIN=mcp.yourdomain.com

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Frontend (baked into JS bundle at build time) ──────────────────────────────
VITE_SUPABASE_URL=https://yourproject.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Auth / Security ───────────────────────────────────────────────────────────
# Random 32-byte hex string — used to encrypt OAuth tokens at rest
ENCRYPTION_KEY=

# ── Self-host ─────────────────────────────────────────────────────────────────
# Master self-host switch. SELF_HOSTED=true unlocks ALL features (no plan
# gating), turns off usage metering + billing, and tells the UI to stop
# enforcing plans. Set this on every self-hosted instance.
SELF_HOSTED=true

# DISABLE_SIGNUPS=true closes public registration: the FIRST account created
# becomes the owner, and after that nobody can self-register. Add teammates via
# the in-app invite (Settings → Team). Leave unset/false for an open instance.
#
# Belt-and-suspenders: also turn OFF "Allow new users to sign up" in your
# Supabase project (Authentication → Sign In / Providers) — that shuts the door
# at the auth layer too, since signup goes browser → Supabase directly.
# DISABLE_SIGNUPS=true

# ── Cloud / team features (optional for self-host) ────────────────────────────
# Skip these for a single-tenant self-host. They power features that the
# hosted Nous Cloud uses, and most self-hosters do not need them.
#
# SIGNAL_HMAC_SECRET signs per-workspace tokens for RB2B / Signalbase ingest.
# Only needed if you ingest from RB2B or Signalbase.
SIGNAL_HMAC_SECRET=

# RESEND_API_KEY sends workspace invitation emails. Only needed if you
# invite teammates to your workspace. Without it, invites still create
# accounts, but no email is sent.
RESEND_API_KEY=
# If you set RESEND_API_KEY, also set the sender to an address on YOUR Resend
# verified domain — otherwise the send is rejected. Reply-to defaults to the
# from address when left blank.
RESEND_FROM_EMAIL=
RESEND_REPLY_TO=

# ── Platform operator allowlists (cloud only — LEAVE EMPTY FOR SELF-HOST) ──────
# These gate the platform-operator surface (CMS, Roadmap, Changelog, Updates,
# Resources) and VIP plan access. Both are EMPTY by default, which means NO
# account can ever reach the admin surface on a self-hosted instance — this is
# intentional. Only the hosted Nous Cloud sets these. Comma-separated emails.
# ADMIN_EMAILS=founder@example.com
# VIP_EMAILS=founder@example.com

# ── CORS (comma-separated allowed origins) ────────────────────────────────────
# Leave unset to allow all origins (fine for self-hosted / local dev).
# Set this on cloud to lock down to your frontend domain.
# CORS_ORIGINS=https://app.opennous.cloud

# ── Integrations ─────────────────────────────────────────────────────────────
# Google OAuth — for Gmail + Calendar sync
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.yourdomain.com/api/oauth/google/callback

# Slack OAuth — for DM polling
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=https://api.yourdomain.com/api/oauth/slack/callback

# Salesforce OAuth — setup guide: docs/providers/salesforce
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=https://api.yourdomain.com/api/workflow-providers/salesforce/oauth/callback
SALESFORCE_LOGIN_URL=https://login.salesforce.com

# Unipile — for LinkedIn webhook
UNIPILE_API_KEY=
UNIPILE_DSN=

# Enrichment providers
PROSPERO_API_KEY=
OPENAI_API_KEY=

# ── Webhook secrets (shared secret to validate inbound webhook payloads) ─────────
# Set these to a random string and configure the same value in each integration's dashboard.
LINKEDIN_WEBHOOK_SECRET=
INSTANTLY_WEBHOOK_SECRET=
CALENDLY_WEBHOOK_SECRET=
FIREFLIES_WEBHOOK_SECRET=
FATHOM_WEBHOOK_SECRET=
RB2B_WEBHOOK_SECRET=

# ── Optional: Stripe (cloud / hosted only) ────────────────────────────────────
# Leave blank for self-hosted. Set these to enable billing UI.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# ── Optional: analytics & monitoring ─────────────────────────────────────────
VITE_POSTHOG_KEY=
VITE_GOOGLE_ANALYTICS_ID=

# ── Optional: docs link override ──────────────────────────────────────────────
# Defaults to https://github.com/opennous/nous
VITE_DOCS_URL=

# ── VITE_API_URL ──────────────────────────────────────────────────────────────
# Leave empty when using the nginx same-domain proxy (single domain, no Caddy).
# Set to https://api.yourdomain.com when api is on a separate subdomain (Caddy / cloud).
# VITE_API_URL=https://api.yourdomain.com

# ── Optional: port (default 80) — only used when running WITHOUT Caddy ─────────
# PORT=80
