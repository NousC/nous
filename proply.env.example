# ── Domains (used by Caddy for SSL + routing) ─────────────────────────────────
APP_DOMAIN=app.yourdomain.com
API_DOMAIN=api.yourdomain.com

# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Frontend (baked into JS bundle at build time) ──────────────────────────────
VITE_SUPABASE_URL=https://yourproject.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Auth / Security ───────────────────────────────────────────────────────────
# Random 32-byte hex string — used to encrypt OAuth tokens at rest
ENCRYPTION_KEY=

# Random string — used to sign per-workspace signal ingest tokens (RB2B, Signalbase)
SIGNAL_HMAC_SECRET=

# Optional: Resend API key — only needed if you want workspace invitation emails to work
# Without this, inviting teammates fails silently. Free tier at https://resend.com
RESEND_API_KEY=

# ── CORS (comma-separated allowed origins) ────────────────────────────────────
# Leave unset to allow all origins (fine for self-hosted / local dev).
# Set this on cloud to lock down to your frontend domain.
# CORS_ORIGINS=https://app.goproply.com

# ── Integrations ─────────────────────────────────────────────────────────────
# Google OAuth — for Gmail + Calendar sync
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://api.yourdomain.com/api/oauth/google/callback

# Slack OAuth — for DM polling
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=https://api.yourdomain.com/api/oauth/slack/callback

# Salesforce OAuth — setup guide: docs/providers/salesforce
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_REDIRECT_URI=https://api.yourdomain.com/api/workflow-providers/salesforce/oauth/callback
SALESFORCE_LOGIN_URL=https://login.salesforce.com

# Unipile — for LinkedIn webhook
UNIPILE_API_KEY=
UNIPILE_DSN=

# Enrichment providers
PROSPERO_API_KEY=
OPENAI_API_KEY=

# ── Webhook secrets (shared secret to validate inbound webhook payloads) ─────────
# Set these to a random string and configure the same value in each integration's dashboard.
LINKEDIN_WEBHOOK_SECRET=
INSTANTLY_WEBHOOK_SECRET=
CALENDLY_WEBHOOK_SECRET=
FIREFLIES_WEBHOOK_SECRET=
FATHOM_WEBHOOK_SECRET=
RB2B_WEBHOOK_SECRET=

# ── Optional: Stripe (cloud / hosted only) ────────────────────────────────────
# Leave blank for self-hosted. Set these to enable billing UI.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# ── Optional: analytics & monitoring ─────────────────────────────────────────
VITE_POSTHOG_KEY=
VITE_GOOGLE_ANALYTICS_ID=

# ── Optional: docs link override ──────────────────────────────────────────────
# Defaults to https://github.com/goproply/proply-crm
VITE_DOCS_URL=

# ── VITE_API_URL ──────────────────────────────────────────────────────────────
# Leave empty when using the nginx same-domain proxy (single domain, no Caddy).
# Set to https://api.yourdomain.com when api is on a separate subdomain (Caddy / cloud).
# VITE_API_URL=https://api.yourdomain.com

# ── Optional: port (default 80) — only used when running WITHOUT Caddy ─────────
# PORT=80
